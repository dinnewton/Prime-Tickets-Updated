# Nginx config for PrimeTickets
# Place this file at: /etc/nginx/sites-available/primetickets
# Then: ln -s /etc/nginx/sites-available/primetickets /etc/nginx/sites-enabled/
# Then run: sudo certbot --nginx -d yourdomain.com

server {
    listen 80;
    server_name yourdomain.com www.yourdomain.com;

    # Let Certbot handle HTTPS redirect after first run
    # (Certbot will modify this file automatically)

    location / {
        proxy_pass         http://localhost:5000;
        proxy_http_version 1.1;

        # Required for Socket.io WebSocket upgrade
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # Increase timeout for long-polling
        proxy_read_timeout 86400;
    }

    # Serve uploaded event images directly from disk (faster)
    location /uploads/ {
        alias /var/www/primetickets/backend/uploads/;
        expires 30d;
        add_header Cache-Control "public";
    }
}
