# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# ─── M-Pesa Daraja API ────────────────────────────────────────────────────────
# Get credentials at https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# Must be your real public HTTPS domain — Safaricom won't call localhost
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback

# sandbox | production  (switch to production when approved by Safaricom)
MPESA_ENV=sandbox

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Gmail: enable "App Passwords" at myaccount.google.com/apppasswords
# SendGrid: use smtp.sendgrid.net, port 587, user=apikey, pass=<your-api-key>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here

# ─── WhatsApp & SMS (Twilio) ──────────────────────────────────────────────────
# Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# WhatsApp sender — use Twilio sandbox: whatsapp:+14155238886 (testing)
# or your approved number after going live
TWILIO_WHATSAPP_FROM=+14155238886

# SMS sender — a Twilio phone number you purchased
TWILIO_SMS_FROM=+12025551234

# Country dialling code for normalising local numbers (27=SA, 254=Kenya)
PHONE_COUNTRY_CODE=27
